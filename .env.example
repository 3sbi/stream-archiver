TWITCH_CHANNEL=xqc

# config variables for aiogram/telegram-bot-api
# see https://github.com/aiogram/telegram-bot-api#configuration
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_LOCAL=true

TELEGRAM_API_URL=http://telegram-bot-api:8081
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHANNEL_ID=YOUR_CHANNEL_ID_OR_HANDLE
TELEGRAM_UPLOAD_MODE=video # or document
# TELEGRAM_WATERMARK_TEXT= # channel_name or nothing if watermark is not needed

CHECK_INTERVAL=60
MIN_FREE_DISK_GB=2